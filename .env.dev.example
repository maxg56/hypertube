########################################
# Database (PostgreSQL)
########################################
DB_HOST=postgres
DB_PORT=5432
DB_NAME=hypertube
DB_USER=postgres
DB_PASSWORD=password

########################################
# Redis
########################################
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_ADDR=redis:6379

########################################
# JWT
########################################
JWT_SECRET=dev-super-secret-jwt-key-for-development-only

########################################
# Gateway
########################################
ALLOWED_ORIGINS=http://localhost:8000,https://localhost:8000,http://localhost:8443,https://localhost:8443,http://127.0.0.1:3000,http://127.0.0.1:8000
LOG_LEVEL=debug

########################################
# TMDB API (required — https://www.themoviedb.org/settings/api)
########################################
TMDB_API_KEY=your-tmdb-api-key-here

########################################
# SMTP
########################################
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=your-email@gmail.com
FROM_NAME=Hypertube
FRONTEND_URL=http://localhost:8000

########################################
# Subtitles (optional — https://www.opensubtitles.com/consumers)
########################################
OPENSUBTITLES_API_KEY=your-opensubtitles-api-key-here
OPENSUBTITLES_USERNAME=
OPENSUBTITLES_PASSWORD=

########################################
# Frontend (Next.js)
########################################
NEXT_PUBLIC_API_URL=https://localhost:8443/api/v1

########################################
# Flags
########################################
GIN_MODE=debug
AUTO_MIGRATE=true
LOG_LEVEL=debug

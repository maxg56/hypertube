########################################
# Gateway
########################################
PORT=8080
JWT_SECRET=your-super-secret-jwt-key-change-in-production
ALLOWED_ORIGINS=http://localhost:8000,https://localhost:8000,https://localhost:8443,http://127.0.0.1:3000,http://127.0.0.1:8000

########################################
# Database (PostgreSQL)
########################################
DB_HOST=postgres
DB_PORT=5432
DB_NAME=hypertube
DB_USER=postgres
DB_PASSWORD=password

########################################
# Redis
########################################
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_ADDR=redis:6379

########################################
# Service URLs (Docker internal)
########################################
AUTH_SERVICE_URL=http://auth-service:8001
USER_SERVICE_URL=http://user-service:8002
LIBRARY_SERVICE_URL=http://library-service:8003
TORRENT_SERVICE_URL=http://torrent-service:8004
COMMENT_SERVICE_URL=http://comment-service:8005
WORKER_SERVICE_URL=http://worker-service:8006

########################################
# Frontend (Next.js)
########################################
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
HOSTNAME=localhost

########################################
# TMDB API (for library-service)
########################################
TMDB_API_KEY=your-tmdb-api-key-here

########################################
# SMTP
########################################
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=mail.example@gmail.com
SMTP_PASSWORD=
FROM_EMAIL=mail.example@gmail.com
FROM_NAME=Hypertube

########################################
# Frontend URL (for email links)
########################################
FRONTEND_URL=http://localhost:3000

########################################
# Torrent / Stream
########################################
TORRENT_DOWNLOAD_PATH=/data/torrents
STREAM_BUFFER_SIZE=10

########################################
# Development
########################################
LOG_LEVEL=debug
GIN_MODE=debug
